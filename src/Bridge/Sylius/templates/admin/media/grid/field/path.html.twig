{% set media = data %}

<span class="media-name">{{ media.filename}}</span>
<form action="{{ path('joli_media_sylius_admin_rename') }}" class="media-rename-form d-none" method="POST">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('media_rename') }}">
    <input type="hidden" name="oldPath" class="media-rename-old-path" value="{{ media.path }}">
    <input type="hidden" name="newPath" class="media-rename-new-path" value="">
    <div class="input-group input-group-sm">
        <input type="text" class="form-control media-rename-input" value="{{ media.filename }}">
        <button type="submit" class="btn btn-primary">
            {{ ux_icon('tabler:check') }}
        </button>
        <button type="button" class="btn btn-secondary media-rename-cancel-btn">
            {{ ux_icon('tabler:x') }}
        </button>
    </div>
</form>
