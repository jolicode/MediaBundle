{% set path = '#' %}

{% set message = action.label %}
{% if message is empty %}
    {% set message = 'sylius.ui.create' %}
{% endif %}

<a href="{{ path }}" class="btn" data-component="media-add">
    {{ ux_icon(action.icon|default('tabler:plus'), {'class': 'icon dropdown-item-icon'}) }}
    {{ message|trans }}
</a>
