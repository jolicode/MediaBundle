{% if product.imagesByType('thumbnail') is not empty %}
    {% set path = product.imagesByType('thumbnail').first.path %}
{% elseif product.images.first %}
    {% set path = product.images.first.path %}
{% else %}
    {% set path = null %}
{% endif %}

{% set alt = 'sylius.ui.product'|trans ~ ' ' ~ product.name ~ ' ' ~ 'sylius.ui.image'|trans %}

{% if path is not null %}
    {{ component('joli:Img', attributes.defaults({
        path: path,
        variation: filter|default('sylius_shop_product_thumbnail'),
        class: 'img-fluid',
        'data-test-main-image': ''
    }).all()) }}
{% else %}
    <img {{ attributes.defaults({ class: 'img-fluid' }) }} src="{{ asset('bundles/syliusui/images/200x200.png') }}" {{ sylius_test_html_attribute('main-image') }} alt="{{ alt }}" />
{% endif %}
