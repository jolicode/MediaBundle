{% trans_default_domain 'JoliMediaSyliusAdminBundle' %}

<div class="joli-media-choose-container">
    <div class="gallery">
        {% if current_key %}
            <ul class="gallery-grid gallery-grid--folders">
                <li class="gallery-grid-item gallery-grid-item--back">
                    <a href="{{ path('joli_media_sylius_admin_choose', { key: current_key|split('/')|slice(0, -1)|join('/') }) }}" class="gallery-grid-item__link">
                        <span class="gallery-grid-item__icon">{{ ux_icon('mdi:arrow-left-bold') }}</span>
                        <span class="gallery-grid-item__name">Parent</span>
                    </a>
                </li>
            </ul>
        {% endif %}

        <ul class="gallery-grid gallery-grid--files">
        {% for media in medias %}
            {% if media.isStored %}
                <li class="gallery-grid-item">
                    <a class="gallery-grid-item__link"
                       href="#"
                       data-media-folder="{{ current_key }}"
                       data-media-url="{{ media.path }}"
                       data-media-full-url="{{ media.url }}"
                       data-media-type="{{ media.fileType }}"
                       data-media-template="{{ include('@JoliMediaSyliusAdmin/_preview.html.twig', { media: media, className: 'media-preview' })|escape }}"
                       data-media-original-template="{{ include('@JoliMediaSyliusAdmin/_preview.html.twig', { media: media, variation: false })|escape }}"
                    >
                        <span class="media-preview">
                            {{ include('@JoliMediaSyliusAdmin/_as_image.html.twig', { media: media, skipAutoDimensions: true }) }}
                        </span>
                        <span class="gallery-grid-item__name">{{ media.filename }}</span>
                    </a>
                </li>
            {% endif %}
        {% endfor %}

        {% if medias is empty and directories is empty %}
            <li class="gallery-grid-item">
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle"></i> {{ 'no_file_found'|trans }}
                </div>
            </li>
        {% endif %}
        </ul>
    </div>
</div>
