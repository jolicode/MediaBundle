{% set definition = hookable_metadata.context.resources.definition %}
{% set directories = hookable_metadata.context.directories %}

{% set key = hookable_metadata.context.key %}
{% set current_key = hookable_metadata.context.current_key %}
{% set parent_key = current_key is empty ? '' : (('/' in current_key) ? current_key|split('/')|slice(0, -1)|join('/') : '') %}

{% if not current_key == ''%}
<tr class="item position-relative">
    {% for field in definition.enabledFields|sylius_sort_by('position') %}
        <td>
            {% if field.name == 'image' %}
                <a href="{{ path('joli_media_sylius_admin_explore', { 'key': parent_key }) }}" class="nav-link text-decoration-none text-dark">
                    {{ ux_icon('mdi:arrow-left-bold') }}
                    Back
                </a>
            {% endif %}
        </td>
    {% endfor %}
</tr>
{% endif %}
{% for directory in directories %}
    <tr class="item position-relative">
        {% for field in definition.enabledFields|sylius_sort_by('position') %}
            <td {% if field.options.vars.td_class is defined %}  class="{{ field.options.vars.td_class }}"{% endif %}>
                <a class="stretched-link text-decoration-none" href="{{ path('joli_media_sylius_admin_explore', {'key': directory}) }}">
                    {% if field.name == 'image' %}
                        {{ ux_icon('tabler:folder') }}
                    {% elseif field.name == 'path' %}
                        <code>{{ directory|joli_media_admin_basename }}</code>
                    {% elseif field.name == 'fileType' %}
                        <div class="badge bg-blue-lt">{{ 'Directory' }}</div>
                    {% else %}
                    {% endif %}
                </a>
            </td>
        {% endfor %}
    </tr>
{% endfor %}