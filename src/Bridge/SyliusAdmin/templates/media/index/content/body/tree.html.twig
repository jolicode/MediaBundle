{% set directories = hookable_metadata.context.directories %}
{% set key = hookable_metadata.context.key %}
{% set current_key = hookable_metadata.context.current_key %}
{% set parent_key = current_key is empty ? '' : (('/' in current_key) ? current_key|split('/')|slice(0, -1)|join('/') : '') %}

{% macro folder_row(directory, current_key) %}
{% set depth = directory|split('/')|length - 1 %}
{% set indent_style = 'padding-left: ' ~ ((depth + 1) * 16) ~ 'px;' %}
<li class="nav-item folder-item" data-directory="{{ directory }}" style="{{ indent_style }}">
    <div class="nav-link d-flex align-items-center gap-2">
        <a href="{{ path('joli_media_sylius_admin_explore', { 'key': directory }) }}" class="flex-grow-1 text-decoration-none text-dark">
            {{ ux_icon('ph:folder-fill') }}
            <span class="folder-name">{{ directory|split('/')|last }}</span>
        </a>
        <button type="button" class="btn btn-sm btn-outline-secondary folder-edit-btn" data-bs-toggle="tooltip" title="Rename">
            {{ ux_icon('tabler:pencil') }}
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary folder-delete-btn" data-bs-toggle="tooltip" title="Delete">
            {{ ux_icon('tabler:trash') }}
        </button>
    </div>
    <form class="folder-rename-form d-none px-3 py-2">
        <div class="input-group input-group-sm">
            <input type="text" class="form-control folder-rename-input" value="{{ directory }}">
            <button type="submit" class="btn btn-primary">
                {{ ux_icon('tabler:check') }}
            </button>
            <button type="button" class="btn btn-secondary folder-cancel-btn">
                {{ ux_icon('tabler:x') }}
            </button>
        </div>
    </form>
</li>
{% endmacro %}

<div class="col-3">
    <div class="card" data-create-directory-path="{{ path('joli_media_sylius_admin_create_directory') }}" data-rename-directory-path="{{ path('joli_media_sylius_admin_rename') }}" data-delete-directory-path="{{ path('joli_media_sylius_admin_delete_directory') }}">
        <div class="card-header">
            <h3 class="card-title">Folders</h3>
            <div class="ms-auto">
                <button type="button" class="btn btn-sm btn-primary folder-create-btn" data-bs-toggle="tooltip" title="Create folder">
                    {{ ux_icon('tabler:folder-plus') }}
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <form class="folder-create-form d-none px-2 py-2" id="folder-create-form">
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control folder-create-input" placeholder="New folder name">
                    <button type="submit" class="btn btn-primary">
                        {{ ux_icon('tabler:check') }}
                    </button>
                    <button type="button" class="btn btn-secondary folder-create-cancel-btn">
                        {{ ux_icon('tabler:x') }}
                    </button>
                </div>
            </form>
            <ul class="folder-tree nav nav-pills flex-column px-2 py-2" id="folder-tree">
                <li class="nav-item">
                    <a href="{{ path('joli_media_sylius_admin_explore', { 'key': '' }) }}" class="nav-link text-decoration-none {{ current_key is empty ? 'text-primary fw-semibold' : 'text-dark' }}">
                        {{ ux_icon('ph:house-fill') }}
                        Root
                    </a>
                </li>
                {% if current_key is not empty %}
                    {% if parent_key is not empty %}
                    <li class="nav-item" style="padding-left: 16px;">
                        <a href="{{ path('joli_media_sylius_admin_explore', { 'key': parent_key }) }}" class="nav-link text-decoration-none text-dark">
                            {{ ux_icon('mdi:arrow-left-bold') }}
                            Back to {{ parent_key|split('/')|last }}
                        </a>
                    </li>
                    {% endif %}
                    <li class="nav-item" style="padding-left: 16px;">
                        <span class="nav-link text-decoration-none text-primary fw-semibold">
                            {{ ux_icon('ph:folder-fill') }}
                            {{ current_key|split('/')|last }}
                        </span>
                    </li>
                {% endif %}
                {% for directory in directories %}
                    {{ _self.folder_row(directory, current_key) }}
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
