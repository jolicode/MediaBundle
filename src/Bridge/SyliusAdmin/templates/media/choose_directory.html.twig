{% trans_default_domain 'JoliMediaSyliusAdminBundle' %}

<div class="folder-choice-content">
    {% if parent_key is defined and parent_key != current_key %}
        <div class="folder-parent">
            <a href="{{ path('joli_media_sylius_admin_choose', { key: parent_key }) }}" 
               data-folder-path="{{ parent_key }}">
                <span class="folder-icon">{{ ux_icon('tabler:folder-up') }}</span>
                <span class="folder-name">{{ 'action.parent'|trans }}</span>
            </a>
        </div>
    {% endif %}

    {% if directories|length > 0 %}
        <ul class="gallery-grid gallery-grid--folders mb-2">
            {% for directory in directories %}
                <li class="gallery-grid-item">
                    <a href="{{ path('joli_media_sylius_admin_choose', { key: directory }) }}" 
                       class="gallery-grid-item__link"
                       data-folder-path="{{ directory }}">
                        <span class="gallery-grid-item__icon">
                            {{ ux_icon('tabler:folder', {class: 'mh-100'}) }}
                        </span>
                        <span class="gallery-grid-item__name">{{ directory|split('/')|last }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    <ul class="gallery-grid gallery-grid--files mb-2">
        {% for media in medias %}
            {% if media.isStored %}
                <li class="gallery-grid-item">
                    <a class="gallery-grid-item__link"
                       href="#"
                       data-media-folder="{{ current_key }}"
                       data-media-url="{{ media.path }}"
                       data-media-full-url="{{ media.url }}"
                       data-media-type="{{ media.fileType }}"
                       data-media-template="{{ include('@JoliMediaSyliusAdmin/_preview.html.twig', { media: media, className: 'media-preview' })|escape }}"
                       data-media-original-template="{{ include('@JoliMediaSyliusAdmin/_preview.html.twig', { media: media, variation: false })|escape }}"
                    >
                        <span class="media-preview">
                            {{ include('@JoliMediaSyliusAdmin/_as_image.html.twig', { media: media, skipAutoDimensions: true, iconAttributes: { class: 'mh-100' } }) }}
                        </span>
                        <span class="gallery-grid-item__name">{{ media.filename }}</span>
                    </a>
                </li>
            {% endif %}
        {% endfor %}
    </ul>
</div>
