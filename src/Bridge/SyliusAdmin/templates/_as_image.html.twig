{% trans_default_domain 'JoliMediaSyliusAdminBundle' %}

{%- if media.fileType == 'image' -%}
    <twig:joli:Img
        media="{{ media }}"
        class="{{ className|default(null) }}"
        variation="{{ variation is defined and variation == false ? null : variation|default('joli_media_sylius_admin') }}"
        skipAutoDimensions="{{ skipAutoDimensions|default(false) }}"
    />
{%- else -%}
    {% if media.fileType == 'pdf' %}
        {{ ux_icon('tabler:file-type-pdf') }}
    {% elseif media.fileType == 'video' %}
        {{ ux_icon('tabler:video') }}
    {% elseif media.fileType == 'audio' %}
        {{ ux_icon('gridicons:audio') }}
    {% elseif media.fileType == 'text' %}
        {{ ux_icon('fa7-solid:file-lines') }}
    {% else %}
        {{ ux_icon('tabler:file') }}
    {% endif %}
{%- endif -%}
