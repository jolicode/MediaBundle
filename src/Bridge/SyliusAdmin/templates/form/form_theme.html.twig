{% block joli_media_sylius_admin_choice_widget %}
    <template id="template-null-label-{{ id }}">
        <span class="text-muted">{{ 'media.unavailable.simple'|trans(domain: 'JoliMediaSyliusAdminBundle') }}</span>
    </template>

    <div class="media-choice js-joli-media-choice-container{% if media is empty %} empty{% endif %}" data-media-id="{{ id }}">
        <span id="joli-media-container_{{ id }}">
            {% if media is not empty %}
                {{ include('@JoliMediaSyliusAdmin/_preview.html.twig', { className: 'media-preview' }) }}
            {% else %}
                {{ include('@JoliMediaSyliusAdmin/form/null_label.html.twig') }}
            {% endif %}
        </span>
        <span class="media-choice__actions">
            <span class="btn-group">
                <a
                    href="{{ path('joli_media_sylius_admin_choose', { key: folder }) }}"
                    class="btn btn-sm btn-link text-primary joli-media-choice-edit"
                >
                    <i class="fas fa-plus"></i> {{ 'action.choose_a_file'|trans(domain: 'JoliMediaSyliusAdminBundle') }}
                </a>
                <button
                    class="btn btn-sm btn-link text-danger ms-2 hide-when-empty joli-media-choice-delete"
                >
                    <i class="fas fa-minus-circle"></i> {{ 'action.remove'|trans(domain: 'JoliMediaSyliusAdminBundle') }}
                </button>
            </span>
        </span>
        {{- block('form_widget_simple') -}}
    </div>
    <div id="modal-media-choice_{{ id }}" class="modal-media-choice modal fade" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body">
                </div>
                <div class="modal-footer">
                    <button type="button" data-bs-dismiss="modal" class="btn btn-secondary">
                        <span class="btn-label">{{ 'action.cancel'|trans(domain: 'JoliMediaSyliusAdminBundle') }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block null_label %}
    <span class="text-muted">{{ 'media.unavailable.simple'|trans(domain: 'JoliMediaSyliusAdminBundle') }}</span>
{% endblock %}
